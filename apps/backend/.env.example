# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development          # "development" or "production"
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@127.0.0.1:5433/podevents?sslmode=disable

# ─── Spotify OAuth ────────────────────────────────────────────────────────────
# Get from: https://developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Must match EXACTLY what you set in Spotify dashboard → Redirect URIs
SPOTIFY_REDIRECT_URL=http://localhost:8080/api/v1/auth/spotify/callback

# ─── Token Encryption ─────────────────────────────────────────────────────────
# AES-256 key for encrypting Spotify tokens in DB (base64-encoded, 32 bytes).
# Generate: make generate-encryption-key
# WARNING: changing this after storing tokens breaks all existing tokens.
TOKEN_ENCRYPTION_KEY=5XIopWgByAlpGdEs641pbVGJ+cH1ny+WPiRTsLca8oY=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN_HOURS=24
JWT_SECRET=changemeplzgeneraterandomkeyhere # generate with openssl rand -base64 32